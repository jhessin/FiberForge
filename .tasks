[console]
cwd=$(VIM_ROOT)
command=textual console
output=terminal
close=1

[test]
cwd=<root>

command=uv run ipython
output=terminal
save=1

[run:debug]
cwd=$(VIM_ROOT)

command=uv run textual run --dev fiberforge

output=terminal
pos=external
close=0
save=1


[run:release]
# Run from the project root so packages like py_tools import cleanly
cwd=$(VIM_ROOT)

command=uv run textual run fiberforge

output=terminal
pos=external
close=1
save=1
