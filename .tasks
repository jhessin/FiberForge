[console]
cwd=$(VIM_ROOT)
command=textual console
close=1

[run:debug]
cwd=$(VIM_ROOT)

command=poetry run textual run --dev fiberforge.app.main:FiberApp

output=terminal
pos=external
close=0
save=1


[run:release]
# Run from the project root so packages like py_tools import cleanly
cwd=$(VIM_ROOT)

# If <root>\.venv\Scripts\python.exe exists, use it; otherwise use plain `python`
# command=$(VIM_ROOT)\py_tools\venv\Scripts\textual.exe serve app.py
command=poetry run textual run fiberforge

output=terminal
pos=external
close=1
save=1
